	)
	(text "Differential Gain = 2 x (Rf / Ri)"
		(exclude_from_sim no)
		(at 115.57 19.558 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "4b8c4041-a4a2-42d0-b7ad-b94e1b2444f8")
	)
	(text "P = V^2 / R\n1W = V^2 / 8\nV^2 = 8\nV = 2.83 Vrms \n2.83 Vrms = Vpp / (2 * sqrt(2))\nVpp = 1V"
		(exclude_from_sim no)
		(at 183.388 64.262 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "8fc10042-0b0f-429e-9d54-ec72bc8738eb")
	)
	(text "Speaker:\nInput Impedance : 8 Ohms\nFrequency Range : 100 Hz - 10kHz\nNominal Power Input : 1 Watt RMS\nMaximum Power Input : 1.5 Watts"
		(exclude_from_sim no)
		(at 182.626 45.72 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "c43a85fc-9e66-4d34-a3cd-ae2836dc51f4")
	)
	(text "Speaker"
		(exclude_from_sim no)
		(at 145.034 47.498 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "e3476915-0426-4ab6-81e0-57c03fec9943")
	)
	(text "DAC Range : 0 to 3.3V \nGain = 1 / 3.3 = ~0.3\n\nDifferential Gain = 2 x (Rf / Ri) \n\n0.3 = 2 x (Rf / Ri)\n0.6 = Rf / Ri\nRi = Rf / 0.6\nLet Rf = 10 kOhms\nRi = 10k / 0.6\nRi = 16.67 kOhms\n\nRf = 10k kOhms\nRi = 16.67 kOhms\n\n"
		(exclude_from_sim no)
		(at 183.388 87.884 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "f1808f45-e94c-4459-b3a1-117ebf117f5d")
	)
